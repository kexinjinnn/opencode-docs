{
  // Minimal, copy-safe opencode config. Everything here is inert until you
  // change values — nothing launches a process or requires extra files.
  // For a fuller, commented reference of all options, see opencode.full.jsonc.

  // Enables editor autocomplete + validation. On a machine blocked from
  // opencode.ai, point this at the mirrored schema in this repo instead, e.g.
  //   "$schema": "/path/to/opencode-docs/site-assets/config.json"
  "$schema": "https://opencode.ai/config.json",

  // Model to use, as "provider/model". Change to whatever you have access to.
  "model": "anthropic/claude-opus-4-8",
  // Cheaper model for side tasks (titles, summaries).
  "small_model": "anthropic/claude-haiku-4-5",

  // Don't try to self-update (blocked machine can't reach opencode.ai).
  "autoupdate": false
}
